{
	$schema: "https://docs.renovatebot.com/renovate-schema.json",
	extends: [
		"config:recommended",
		"schedule:weekly",
		"group:allNonMajor",
		":semanticCommits",
	],
	labels: ["dependencies"],
	rangeStrategy: "update-lockfile",
	postUpdateOptions: ["pnpmDedupe"],
	packageRules: [
		{
			matchDepTypes: ["peerDependencies", "engines"],
			enabled: false,
		},
		{
			matchDatasources: ["npm"],
			minimumReleaseAge: "3 days",
		},
	],
}
